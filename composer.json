{
    "name": "team-incubation/ngo-platform",
    "description": "Team Incubation NGO Website and Management Platform",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "dompdf/dompdf": "^3.0",
        "chillerlan/php-qrcode": "^5.0",
        "phpmailer/phpmailer": "^6.9",
        "phpoffice/phpspreadsheet": "^2.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "chillerlan/composer-settings-plugin": true
        }
    }
}
